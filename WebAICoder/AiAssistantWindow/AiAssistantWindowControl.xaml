<UserControl x:Class="WebAICoder.AiAssistantWindow.AiAssistantWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:converters="clr-namespace:WebAICoder.Converters">
    <UserControl.Resources>
        <!-- Конвертеры -->
        <converters:DiffTypeToColorConverter x:Key="DiffTypeToColor"/>
        <converters:DiffTypeToSymbolConverter x:Key="DiffTypeToSymbol"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibility"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <converters:BoolToInverseVisibilityConverter x:Key="BoolToInverseVisibility"/>

        <!-- Стиль для контейнера элементов ComboBox (выпадающий список) -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#0E639C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Полный стиль для ComboBox с переопределением шаблона -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  Focusable="False"
                                  ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- ВАЖНОЕ ИСПРАВЛЕНИЕ: показываем выбранный элемент -->
                                                <ContentPresenter Grid.Column="0"
                                                          Content="{Binding SelectedItem, RelativeSource={RelativeSource FindAncestor, AncestorType=ComboBox}}"
                                                          ContentTemplate="{Binding ItemTemplate, RelativeSource={RelativeSource FindAncestor, AncestorType=ComboBox}}"
                                                          ContentTemplateSelector="{Binding ItemTemplateSelector, RelativeSource={RelativeSource FindAncestor, AncestorType=ComboBox}}"
                                                          ContentStringFormat="{Binding ItemStringFormat, RelativeSource={RelativeSource FindAncestor, AncestorType=ComboBox}}"
                                                          Margin="8,3"
                                                          VerticalAlignment="Center"/>

                                                <!-- Стрелочка -->
                                                <Path Grid.Column="1" 
                                              Fill="#CCCCCC" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"
                                              Data="M 0 0 L 5 5 L 10 0 Z"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- Выпадающий список -->
                            <Popup x:Name="Popup"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           Placement="Bottom"
                           Focusable="False"
                           AllowsTransparency="True">
                                <Grid MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                    Background="#2D2D2D"
                                    BorderBrush="#555555"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для всех кнопок -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0E639C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1177BB"/>
                                <Setter Property="BorderBrush" Value="#1177BB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0A4E7A"/>
                                <Setter Property="BorderBrush" Value="#0A4E7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для всех TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- Стиль для ScrollViewer -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="#1E1E1E"/>
        </Style>

        <!-- Стиль для TextBlock -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>

        <!-- Стиль для Border -->
        <Style TargetType="Border">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderBrush" Value="#3E3E3E"/>
        </Style>

        <!-- Стиль для ItemsControl -->
        <Style TargetType="ItemsControl">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>

        <!-- Стиль для Grid -->
        <Style TargetType="Grid">
            <Setter Property="Background" Value="#1E1E1E"/>
        </Style>

        <!-- Стиль для UserControl -->
        <Style TargetType="UserControl">
            <Setter Property="Background" Value="#1E1E1E"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="5" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- История чата -->
        <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ChatHistoryItems">
                <ItemsControl.Resources>
                    <converters:DiffTypeToColorConverter x:Key="DiffTypeToColor"/>
                    <converters:DiffTypeToSymbolConverter x:Key="DiffTypeToSymbol"/>
                </ItemsControl.Resources>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Заголовок: роль и время -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="Bold" Foreground="White" Text="{Binding Role}"/>
                                <TextBlock Grid.Column="2" Margin="10,0,0,0" Foreground="Gray" FontSize="10" Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                            </Grid>

                            <!-- Текст сообщения -->
                            <TextBlock Grid.Row="1" Foreground="White" Text="{Binding Content}" TextWrapping="Wrap" Margin="0,5,0,0" Visibility="{Binding Content, Converter={StaticResource StringToVisibility}}"/>

                            <!-- Дифф файлов -->
                            <ItemsControl Grid.Row="2" ItemsSource="{Binding FileDiffs}" Margin="0,5,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#555" BorderThickness="1" CornerRadius="3" Padding="5" Margin="0,2" Background="#333">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!-- Имя файла (кликабельное) -->
                                                <TextBlock Grid.Column="0" FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" Text="{Binding ShortFileName}" Margin="0,0,10,0"
                                                   Cursor="Hand" TextDecorations="Underline" Foreground="#4FC1FF" MouseLeftButtonDown="FileName_MouseLeftButtonDown"
                                                   Tag="{Binding FilePath}"/>

                                                <!-- +N зеленым -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                                                    <TextBlock Text="+" Foreground="LightGreen" FontFamily="Consolas" FontWeight="Bold" Visibility="{Binding LinesAdded, Converter={StaticResource IntToVisibility}}"/>
                                                    <TextBlock Foreground="LightGreen" FontFamily="Consolas" Text="{Binding LinesAdded}" Visibility="{Binding LinesAdded, Converter={StaticResource IntToVisibility}}"/>
                                                </StackPanel>

                                                <!-- -N красным -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                                                    <TextBlock Text="−" Foreground="IndianRed" FontFamily="Consolas" FontWeight="Bold" Visibility="{Binding LinesRemoved, Converter={StaticResource IntToVisibility}}"/>
                                                    <TextBlock Foreground="IndianRed" FontFamily="Consolas" Text="{Binding LinesRemoved}" Visibility="{Binding LinesRemoved, Converter={StaticResource IntToVisibility}}"/>
                                                </StackPanel>

                                                <!-- Кнопка "Вернуть" -->
                                                <Button Grid.Column="3" Content="↩ Вернуть" Background="Transparent" Foreground="#CCCCCC" BorderBrush="#555555" BorderThickness="1"
                                                    FontSize="11" Padding="5,2" Cursor="Hand" Click="RevertButton_Click" Tag="{Binding}" VerticalAlignment="Center" HorizontalAlignment="Right"
                                                    Visibility="{Binding IsReverted, Converter={StaticResource BoolToInverseVisibility}}"/>

                                                <TextBlock Grid.Row="1" Foreground="#aaa" FontSize="11" Text="{Binding Explain}" TextWrapping="Wrap" Grid.ColumnSpan="4"
                                                           Visibility="{Binding Explain, Converter={StaticResource StringToVisibility}}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Видимый WebView2 для DeepSeek -->
        <wpf:WebView2 x:Name="DeepSeekWebView" Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" Margin="5 0 0 0">
            <wpf:WebView2.CreationProperties>
                <wpf:CoreWebView2CreationProperties UserDataFolder="C:\Temp\MyExtensionWebView2"/>
            </wpf:WebView2.CreationProperties>
        </wpf:WebView2>

        <!-- Статусная строка -->
        <TextBlock x:Name="StatusTextBlock" Grid.Row="1" Foreground="#808080" FontSize="10" Margin="5,2" Visibility="Visible"/>

        <!-- Поле ввода -->
        <TextBox x:Name="PromptTextBox" Grid.Row="2" Grid.Column="0" Margin="0,5" Background="#333" BorderBrush="#555" Foreground="White"
                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="50" MaxHeight="100" KeyDown="PromptTextBox_KeyDown"/>

        <!-- Нижняя панель: кнопка отправки, выбор модели, очистка -->
        <Grid Grid.Row="3" Grid.Column="0" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="ModelSelector" DockPanel.Dock="Left" Width="150" SelectedIndex="0" SelectionChanged="ModelSelector_SelectionChanged">
                <ComboBoxItem Content="DeepSeek"/>
                <!-- Можно добавить другие модели -->
            </ComboBox>
            <Button Grid.Column="1" x:Name="ModeToggleButton" Content="💬 Спросить" DockPanel.Dock="Left" Click="ModeToggleButton_Click" Margin="5,0,0,0" ToolTip="Режим вопроса по проекту"/>
            <Button Grid.Column="3" x:Name="SendButton" Content="Отправить" DockPanel.Dock="Right" Click="SendButton_Click" Margin="5,0,0,0"/>
        </Grid>
    </Grid>
</UserControl>